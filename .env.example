# ─────────────────────────────────────────────────────────────────────────────
# CaiShen environment configuration — copy to .env and fill in real values.
# .env is gitignored; .env.example is committed as documentation.
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3001
# PostgreSQL (Neon / Supabase / local). Required.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — MUST be set to a long random string in production.
# The code has a dev fallback, but you should always override it.
#   Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

AUTO_SYNC_INTERVAL=60

# ── AI Advisor — model providers ─────────────────────────────────────────────
# Which backend the advisor uses: 'ollama' | 'groq' | 'anthropic'
AI_PROVIDER=ollama

# Anthropic (paid; used only as the high-risk escalation fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq (free tier; fast cloud inference for the main advisor)
#   Get a key at https://console.groq.com  (no credit card required)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── RAG: Ollama (local embeddings) ───────────────────────────────────────────
#   Install Ollama, then: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
# Local chat model for the advisor when AI_PROVIDER=ollama
OLLAMA_CHAT_MODEL=qwen2.5:32b-instruct

# ── RAG: Qdrant (vector store) ───────────────────────────────────────────────
#   docker compose -f server/rag/docker-compose.yml up -d
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tax_sources
# Only if you enabled an API key in docker-compose / Qdrant Cloud:
QDRANT_API_KEY=

# ── Plaid (live bank connections) ────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# ── QuickBooks (optional) ────────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=

# ── Email (2FA codes / notifications) ────────────────────────────────────────
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=465
EMAIL_FROM=
EMAIL_PASS=

# ── Twilio (SMS 2FA, optional) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Misc ─────────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=
ADMIN_EMAIL=
# MASTER_PASSWORD — optional extra gate; leave unset to disable.
MASTER_PASSWORD=
